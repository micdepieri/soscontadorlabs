# =============================================================================
# Portal da Comunidade — Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# Database (Supabase / PostgreSQL)
# DATABASE_URL: use the Transaction pooler URL (port 6543) for app runtime on Vercel.
#   Supabase dashboard → Settings → Database → Connection pooling → Transaction mode
#   Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: direct connection used only for prisma migrate. Use port 5432.
#   Supabase dashboard → Settings → Database → Connection string → URI
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Stripe (for subscriptions)
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price ID for the membership plan
STRIPE_PRICE_ID="price_..."

# App URL (used for Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
