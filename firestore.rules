rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read their own user doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null; // all authenticated users can read profiles
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Videos and materials are readable by authenticated users
    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if false; // admin only via server
    }

    match /materials/{materialId} {
      allow read: if request.auth != null;
      allow write: if false; // admin only via server
    }

    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if false; // admin only via server
    }

    // Posts - authenticated users can read
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if false; // admin only via server
    }

    // Comments - authenticated users can read, authors can write
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.authorId == request.auth.uid;
      allow delete: if false; // admin only via server
    }

    // Ratings - authenticated users can read and write their own
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Subscriptions - admin only via server
    match /subscriptions/{subId} {
      allow read: if request.auth != null;
      allow write: if false; // admin only via server
    }

    // Content requests - admin only via server
    match /content_requests/{reqId} {
      allow read: if false;
      allow write: if false;
    }

    // Settings - admin only via server (never expose to client)
    match /settings/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // Content progress - readable by authenticated users; written by server only
    match /content_progress/{progressId} {
      allow read: if request.auth != null;
      allow write: if false; // server only via /api/content/consume
    }

    // User XP - readable by authenticated users; written by server only
    match /user_xp/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // server only
    }

    // XP transactions - server only
    match /xp_transactions/{txId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
